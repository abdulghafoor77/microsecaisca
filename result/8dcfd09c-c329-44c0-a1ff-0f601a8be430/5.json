{
      "name": "Export CSV - Valid ID, Valid Token",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{auth_token_valid}}", "type": "text" }
        ],
        "url": {
          "raw": "http://localhost:8080/v1/medical/report/export-csv/{{report_id_valid}}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["v1", "medical", "report", "export-csv", "{{report_id_valid}}"]
        }
      }
    },
