{
      "name": "Export Report - Valid ID, Valid Token",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{valid_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "http://localhost:8080/v1/medical/report/export/{{valid_report_id}}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["v1", "medical", "report", "export", "{{valid_report_id}}"]
        }
      }
    },
