    {
      "name": "API6:2023 - Unrestricted Access to Sensitive Business Flows - Automated Export Loop",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "if (!pm.environment.get('loop_counter')) {",
              "    pm.environment.set('loop_counter', 0);",
              "}",
              "let loop_counter = parseInt(pm.environment.get('loop_counter'));",
              "if (loop_counter < 10) {",
              "    pm.environment.set('loop_counter', loop_counter + 1);",
              "    postman.setNextRequest('API6:2023 - Unrestricted Access to Sensitive Business Flows - Automated Export Loop');",
              "} else {",
              "    pm.environment.unset('loop_counter');",
              "}"
            ],
            "type": "text/javascript"
          }
        }
