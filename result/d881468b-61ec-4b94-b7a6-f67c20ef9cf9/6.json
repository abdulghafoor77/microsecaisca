      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "if (!pm.collectionVariables.get('rate_limit_counter')) {",
              "    pm.collectionVariables.set('rate_limit_counter', 0);",
              "}",
              "let cnt = parseInt(pm.collectionVariables.get('rate_limit_counter')) + 1;",
              "pm.collectionVariables.set('rate_limit_counter', cnt);"
            ],
