          {
            "key": "Authorization",
            "value": "Bearer {{valid_token}}"
          }
        ],
        "url": {
          "raw": "http://localhost:8080/v1/medical/report/export-all",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["v1", "medical", "report", "export-all"]
        }
      }
    },
