{
      "name": "API1:2023 - IDOR - Access Own Report (Valid)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{valid_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "http://localhost:8080/v1/medical/report/export/{{own_report_id}}",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "v1",
            "medical",
            "report",
            "export",
            "{{own_report_id}}"
          ]
        }
      }
    },
