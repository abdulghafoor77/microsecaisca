{
      "name": "Export All Medical Reports - Valid Token",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{valid_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "http://localhost:8080/v1/medical/report/export-all",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "v1",
            "medical",
            "report",
            "export-all"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Check for PII leakage (Broken Object Level Authorization)",
              "pm.test(\"No PII fields present\", function () {",
              "    pm.response.to.not.have.jsonBody('patientName');",
              "    pm.response.to.not.have.jsonBody('patientId');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
