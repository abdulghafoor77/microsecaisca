    },
    {
      "name": "Get Report by Another User's ID (BOLA)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{auth_token_other_user}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "http://localhost:8080/demo/reports/{{report_id_other_user}}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["demo", "reports", "{{report_id_other_user}}"]
        }
      }
    },
