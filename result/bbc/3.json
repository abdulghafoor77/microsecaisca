{
      "name": "Valid Report ID (Owned)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{auth_token_valid}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "http://localhost:8080/demo/vuln/report/{{owned_report_id}}",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "demo",
            "vuln",
            "report",
            "{{owned_report_id}}"
          ]
        }
      }
    },
