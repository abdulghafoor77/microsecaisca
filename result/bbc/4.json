{
      "name": "Valid Report ID (Authorized)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{valid_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "http://localhost:8080/demo/vuln/export-csv?id={{valid_report_id}}",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "demo",
            "vuln",
            "export-csv"
          ],
          "query": [
            {
              "key": "id",
              "value": "{{valid_report_id}}"
            }
          ]
        }
      }
    },
