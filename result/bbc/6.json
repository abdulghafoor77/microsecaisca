{
      "name": "Count Reports - Valid Patient ID",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{valid_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "http://localhost:8080/demo/count?patientId={{valid_patient_id}}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["demo", "count"],
          "query": [
            {
              "key": "patientId",
              "value": "{{valid_patient_id}}"
            }
          ]
        }
      }
    },
