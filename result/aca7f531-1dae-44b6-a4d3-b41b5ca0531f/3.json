{
      "name": "API1:2023 - Broken Object Level Authorization",
      "item": [
        {
          "name": "Access own report (valid)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{valid_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/v1/medical/report/export/{{own_report_id}}",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "v1",
                "medical",
                "report",
                "export",
                "{{own_report_id}}"
              ]
            }
          }
        },
        {
          "name": "Access another user's report (should be forbidden)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{valid_token}}"
              }
            ],
            "url": {
