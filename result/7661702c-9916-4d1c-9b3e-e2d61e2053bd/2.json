{
      "name": "Find Reports - Valid Token & Valid pid",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{valid_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "http://localhost:8080/v1/medical/report/find?pid={{valid_pid}}",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "v1",
            "medical",
            "report",
            "find"
          ],
          "query": [
            {
              "key": "pid",
              "value": "{{valid_pid}}"
            }
          ]
        }
      }
    },
